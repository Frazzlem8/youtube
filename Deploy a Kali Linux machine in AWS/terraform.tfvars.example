# -------------------------------------------------------
# Deploy a Kali Linux Machine in AWS - Example Variables
# -------------------------------------------------------
# Copy this file to terraform.tfvars and update the values.
#   cp terraform.tfvars.example terraform.tfvars

aws_region       = "eu-west-2"
project_name     = "kali-linux"

# AMD 64
# instance_type    = "t3.medium"

# ARM 64
instance_type    = "t4g.medium"

root_volume_size = 30
key_pair_name    = "kali-linux-key"

# IMPORTANT: Set this to your public IP for SSH access.
# Find your IP: curl -s https://checkip.amazonaws.com
allowed_ssh_cidr = "YOUR_IP_ADDRESS/32"
