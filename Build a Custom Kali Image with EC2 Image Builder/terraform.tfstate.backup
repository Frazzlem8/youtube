    {
      "mode": "managed",
      "type": "aws_imagebuilder_component",
      "name": "kali_setup",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:imagebuilder:eu-west-2:717226006751:component/kali-image-builder-kali-setup/1.0.15778830/1",
            "change_description": "",
            "data": "# -------------------------------------------------------\n# EC2 Image Builder Component - Kali Linux Custom Setup\n# -------------------------------------------------------\n# This component is executed by Image Builder during the AMI build.\n# It installs tools, hardens the image, and configures defaults.\n\nname: KaliLinuxCustomSetup\ndescription: Installs pentesting tools, utilities, and hardens the Kali Linux image.\nschemaVersion: 1.0\n\nphases:\n  - name: build\n    steps:\n      # -------------------- System Update --------------------\n      - name: SystemUpdate\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Updating package lists...\"\n            - export DEBIAN_FRONTEND=noninteractive\n            - apt-get update -y\n            - echo \"[*] Upgrading installed packages...\"\n            - apt-get upgrade -y\n\n      # -------------------- Core Pentesting Tools --------------------\n      - name: InstallPentestTools\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Installing core pentesting tools...\"\n            - apt-get install -y\n                nmap\n                nikto\n                dirb\n                gobuster\n                sqlmap\n                enum4linux\n                smbclient\n                hydra\n                john\n                hashcat\n                wordlists\n                seclists\n                exploitdb\n                netcat-openbsd\n                socat\n                proxychains4\n                chisel\n                whatweb\n                wfuzz\n                ffuf\n                crackmapexec\n\n      # -------------------- Useful Utilities --------------------\n      - name: InstallUtilities\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Installing utilities...\"\n            - apt-get install -y\n                tmux\n                tree\n                jq\n                unzip\n                curl\n                wget\n                net-tools\n                htop\n                vim\n                git\n                python3-pip\n                pipx\n\n      # -------------------- Install AWS CLI v2 --------------------\n      - name: InstallAWSCLI\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Installing AWS CLI v2...\"\n            - |\n              if ! command -v aws \u0026\u003e/dev/null; then\n                arch=$(dpkg --print-architecture)\n                if [ \"$arch\" = \"arm64\" ] || [ \"$arch\" = \"aarch64\" ]; then\n                  cli_url=\"https://awscli.amazonaws.com/awscli-exe-linux-aarch64.zip\"\n                else\n                  cli_url=\"https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip\"\n                fi\n                curl -s \"$cli_url\" -o \"/tmp/awscliv2.zip\"\n                unzip -q /tmp/awscliv2.zip -d /tmp\n                /tmp/aws/install\n                rm -rf /tmp/aws /tmp/awscliv2.zip\n                echo \"[+] AWS CLI installed: $(aws --version)\"\n              else\n                echo \"[+] AWS CLI already present: $(aws --version)\"\n              fi\n\n      # -------------------- SSH Hardening --------------------\n      - name: HardenSSH\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Hardening SSH configuration...\"\n            - sed -i 's/^#\\?PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config\n            - sed -i 's/^#\\?PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config\n            - sed -i 's/^#\\?X11Forwarding.*/X11Forwarding no/' /etc/ssh/sshd_config\n            - echo \"[+] SSH hardened — root login and password auth disabled\"\n\n      # -------------------- Set Timezone --------------------\n      - name: SetTimezone\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Setting timezone to UTC...\"\n            - timedatectl set-timezone UTC\n\n      # -------------------- Login Banner --------------------\n      - name: ConfigureBanner\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Configuring login banner...\"\n            - |\n              cat \u003e /etc/motd \u003c\u003c 'BANNER'\n\n              ╔══════════════════════════════════════════╗\n              ║   Custom Kali Linux — EC2 Image Builder  ║\n              ║   Built with baked-in pentesting tools   ║\n              ╚══════════════════════════════════════════╝\n\n              BANNER\n\n      # -------------------- XFCE Desktop --------------------\n      - name: InstallXFCE\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Installing XFCE desktop environment...\"\n            - export DEBIAN_FRONTEND=noninteractive\n            - apt-get install -y\n                kali-desktop-xfce\n                dbus-x11\n\n      # -------------------- xRDP --------------------\n      - name: InstallXRDP\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Installing and configuring xRDP...\"\n            - export DEBIAN_FRONTEND=noninteractive\n            - apt-get install -y xrdp xorgxrdp\n            - adduser xrdp ssl-cert\n            - systemctl enable xrdp\n            - systemctl enable xrdp-sesman\n            - |\n              # Set a default password for the kali user (xRDP requires PAM auth)\n              echo 'kali:kali' | chpasswd\n            - |\n              # Configure xRDP to use XFCE\n              cat \u003e /etc/xrdp/startwm.sh \u003c\u003c 'EOF'\n              #!/bin/sh\n              if [ -r /etc/default/locale ]; then\n                . /etc/default/locale\n                export LANG LANGUAGE\n              fi\n              unset DBUS_SESSION_BUS_ADDRESS\n              unset XDG_RUNTIME_DIR\n              exec /usr/bin/startxfce4\n              EOF\n              chmod 755 /etc/xrdp/startwm.sh\n            - |\n              # Set Xorg session port to -1 (sesman-controlled)\n              sed -i '/^\\[Xorg\\]/,/^\\[/ s/^port=.*/port=-1/' /etc/xrdp/xrdp.ini\n            - |\n              # Ensure xrdp-sesman uses Xorg session\n              sed -i 's/^param=Xvnc$/param=Xorg/' /etc/xrdp/sesman.ini 2\u003e/dev/null || true\n            - |\n              # Create polkit rule to allow colord without auth (prevents dialog prompts)\n              cat \u003e /etc/polkit-1/localauthority/50-local.d/45-allow-colord.pkla \u003c\u003c 'EOF'\n              [Allow Colord all Users]\n              Identity=unix-user:*\n              Action=org.freedesktop.color-manager.create-device;org.freedesktop.color-manager.create-profile;org.freedesktop.color-manager.delete-device;org.freedesktop.color-manager.delete-profile;org.freedesktop.color-manager.modify-device;org.freedesktop.color-manager.modify-profile\n              ResultAny=no\n              ResultInactive=no\n              ResultActive=yes\n              EOF\n            - echo \"[+] xRDP configured to use XFCE on port 3389\"\n\n      # -------------------- Cleanup --------------------\n      - name: Cleanup\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Cleaning up...\"\n            - apt-get autoremove -y\n            - apt-get clean\n            - rm -rf /var/lib/apt/lists/*\n            - rm -rf /tmp/*\n            - echo \"[+] Build phase complete\"\n\n  - name: validate\n    steps:\n      - name: ValidateTools\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Validating installed tools...\"\n            - command -v nmap\n            - command -v gobuster\n            - command -v sqlmap\n            - command -v ffuf\n            - command -v hydra\n            - command -v aws\n            - command -v tmux\n            - command -v jq\n            - command -v xrdp\n            - command -v startxfce4\n            - echo \"[+] All tools validated successfully\"\n\n  - name: test\n    steps:\n      - name: TestToolVersions\n        action: ExecuteBash\n        inputs:\n          commands:\n            - echo \"[*] Testing tool versions...\"\n            - nmap --version | head -1\n            - aws --version\n            - python3 --version\n            - echo \"[+] All tests passed\"\n",
            "date_created": "2026-05-16T19:10:40.635Z",
            "description": "Installs pentesting tools, hardens SSH, and configures the Kali image",
            "encrypted": true,
            "id": "arn:aws:imagebuilder:eu-west-2:717226006751:component/kali-image-builder-kali-setup/1.0.15778830/1",
            "kms_key_id": "",
            "name": "kali-image-builder-kali-setup",
            "owner": "717226006751",
            "platform": "Linux",
            "skip_destroy": false,
            "supported_os_versions": null,
            "tags": {
              "Name": "kali-image-builder-kali-setup"
            },
            "tags_all": {
              "ManagedBy": "Terraform",
              "Name": "kali-image-builder-kali-setup",
              "Project": "Kali-Image-Builder"
            },
            "type": "BUILD",
            "uri": null,
            "version": "1.0.15778830"
          },
          "sensitive_attributes": [],
          "private": "bnVsbA==",
          "create_before_destroy": true
        }
      ]
    },
